{
  "extends": "../typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/ui": ["./src/ui/index.ts"],
      "@/ui/*": ["./src/ui/*"],
      "@snappin/shared": ["../shared/src/index.ts"],
      "@snappin/shared/*": ["../shared/src/*"],
      "@snappin/design-system": ["./src/index.ts"],
      "@snappin/design-system/*": ["./src/*"]
    },
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "scripts/**/*.ts", "turbo/**/*.ts"],
  "exclude": ["node_modules", "dist", ".storybook", "src/**/*.stories.tsx"]
}
